<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/solplay_orange">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textColor="@color/solplay_white"
        android:textSize="42sp"
        android:textStyle="bold" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/tagline"
        android:textColor="@color/solplay_white"
        android:textSize="14sp" />

    <View
        android:layout_width="60dp"
        android:layout_height="4dp"
        android:layout_marginTop="20dp"
        android:background="@color/solplay_green" />

    <!-- Visible uniquement pendant une connexion automatique déclenchée par
         une assignation admin détectée au démarrage (voir SplashActivity) -
         évite que l'app semble figée pendant le téléchargement des chaînes. -->
    <TextView
        android:id="@+id/tvSplashStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Connexion à votre abonnement…"
        android:textColor="@color/solplay_white"
        android:textSize="12sp"
        android:visibility="gone" />

</LinearLayout>
