<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Lecteur vidéo -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:use_controller="true" />

    <!-- ── Spinner de chargement centré ── -->
    <ProgressBar
        android:id="@+id/progressBuffering"
        style="?android:attr/progressBarStyleLarge"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_gravity="center"
        android:indeterminateTint="@color/solplay_orange"
        android:visibility="gone" />

    <!-- Nom de la chaîne (haut-gauche) -->
    <TextView
        android:id="@+id/tvChannelTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="12dp"
        android:background="@color/solplay_orange"
        android:padding="6dp"
        android:textColor="@color/solplay_white"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Programme EPG en cours -->
    <TextView
        android:id="@+id/tvProgramInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_marginStart="12dp"
        android:layout_marginTop="46dp"
        android:background="@color/solplay_panel_overlay"
        android:padding="6dp"
        android:textColor="@color/solplay_white"
        android:textSize="12sp"
        android:visibility="gone" />

    <!-- ── Barre de boutons haut-droite ── -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|end"
        android:layout_margin="12dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@color/solplay_panel_overlay"
        android:padding="2dp">

        <!-- Favori -->
        <TextView
            android:id="@+id/btnFavorite"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="☆ Favori"
            android:textColor="@color/solplay_white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone" />

        <!-- Séparateur -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="@color/solplay_white_60"
            android:layout_marginHorizontal="4dp" />

        <!-- Ratio d'image -->
        <TextView
            android:id="@+id/btnAspectRatio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="⛶ Ajuster"
            android:textColor="@color/solplay_white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone" />

        <!-- Séparateur -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="@color/solplay_white_60"
            android:layout_marginHorizontal="4dp" />

        <!-- Catch-up / Replay -->
        <TextView
            android:id="@+id/btnCatchup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="⏮ Replay"
            android:textColor="@color/solplay_white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone" />

        <!-- Séparateur -->
        <View
            android:layout_width="1dp"
            android:layout_height="20dp"
            android:background="@color/solplay_white_60"
            android:layout_marginHorizontal="4dp" />

        <!-- Liste chaînes -->
        <TextView
            android:id="@+id/btnChannelList"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:text="☰ Chaînes"
            android:textColor="@color/solplay_white"
            android:textStyle="bold"
            android:textSize="13sp"
            android:focusable="true"
            android:clickable="true"
            android:visibility="gone" />

    </LinearLayout>

    <!-- ── Panneau latéral chaînes (droite) ── -->
    <LinearLayout
        android:id="@+id/channelListPanel"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:background="@color/solplay_panel_overlay"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/solplay_panel_header_overlay"
            android:padding="12dp"
            android:text="▸  Changer de chaîne   (◄ pour fermer)"
            android:textColor="@color/solplay_white"
            android:textStyle="bold"
            android:textSize="13sp" />

        <EditText
            android:id="@+id/etSideSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10dp"
            android:background="@drawable/bg_search_overlay"
            android:hint="Rechercher…"
            android:textColorHint="@color/solplay_white_60"
            android:textColor="@color/solplay_white"
            android:inputType="text"
            android:maxLines="1"
            android:padding="10dp"
            android:focusable="true"
            android:focusableInTouchMode="true" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerSideChannels"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:focusable="true"
            android:descendantFocusability="afterDescendants" />

    </LinearLayout>

</FrameLayout>
