<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/solplay_white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/solplay_orange"
        android:padding="16dp"
        android:text="@string/app_name"
        android:textColor="@color/solplay_white"
        android:textSize="20sp"
        android:textStyle="bold" />

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabIndicatorColor="@color/solplay_orange"
        app:tabSelectedTextColor="@color/solplay_orange"
        app:tabTextColor="@color/solplay_black" />

    <EditText
        android:id="@+id/etSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="12dp"
        android:background="@color/solplay_gray"
        android:hint="Rechercher..."
        android:inputType="text"
        android:maxLines="1"
        android:padding="10dp" />

    <TextView
        android:id="@+id/tvEmpty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:text="Aucune chaîne trouvée."
        android:textColor="@color/solplay_text_secondary"
        android:visibility="gone" />

    <!-- Mise en page "maître-détail" : colonne de gauche = bouquets (catégories),
         colonne de droite = chaînes du bouquet sélectionné. Évite d'avoir à parcourir
         toutes les chaînes pour en trouver une : on choisit d'abord le bouquet. -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerBouquets"
            android:layout_width="120dp"
            android:layout_height="match_parent"
            android:background="@color/solplay_gray" />

        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/solplay_text_secondary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerChannels"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1" />

    </LinearLayout>

</LinearLayout>
