<?xml version="1.0" encoding="utf-8"?>
<!-- Fond légèrement dégradé (centre un peu plus clair que les bords), pour
     un rendu plus profond que l'aplat noir uni, sans changer la teinte de
     marque de l'app. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:type="radial"
        android:gradientRadius="480dp"
        android:centerX="0.5"
        android:centerY="0.35"
        android:startColor="#22262E"
        android:endColor="@color/solplay_black" />
</shape>
